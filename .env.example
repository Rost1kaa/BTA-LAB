# ──────────────────────────────────────────────
# BTA LAB — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Never commit .env or real secrets to version control.

# Supabase URL (public — safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (public — safe for Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role key (server-side only — NEVER expose to client)
# Find this in Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Canonical production origin, used for sitemap/robots and HTTPS-safe metadata.
# Example: https://bta-lab.com
NEXT_PUBLIC_SITE_URL=

# Optional: restrict Server Action POST origins in production.
# Comma-separated hostnames/origins, for example: bta-lab.com,https://bta-lab.com
SERVER_ACTION_ALLOWED_ORIGINS=

# Optional: Cloudflare Turnstile. Login/contact/quiz verification is enforced
# automatically when the secret key is set.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: fixed Next.js Server Actions encryption key for multi-instance hosting.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Optional: webhook target for repeated security-event alerts.
SECURITY_ALERT_WEBHOOK_URL=

# ── Seed Script Configuration (required) ────────────────────────────────

# The seed script automatically resolves the admin user by email.
# If the user does not exist, ADMIN_PASSWORD is required to create one.
# Password must be at least 12 characters and include mixed character types.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=
